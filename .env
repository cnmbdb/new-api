# Railway 会自动注入这些 PostgreSQL 变量
# 在 Railway 仪表盘 → PostgreSQL → Connect → 复制变量名
POSTGRES_USER=${POSTGRES_USER}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
PGHOST=${POSTGRES_HOST}
PGPORT=${POSTGRES_PORT}
PGDATABASE=${POSTGRES_DATABASE}

# Railway 会自动注入这些 Redis 变量
# 如果使用 Railway Redis，变量名类似 REDIS_HOST, REDIS_PORT, REDIS_PASSWORD
REDISUSER=${REDIS_USER}
REDISPASSWORD=${REDIS_PASSWORD}
REDISHOST=${REDIS_HOST}
REDISPORT=${REDIS_PORT}

# 日志配置
ERROR_LOG_ENABLED=true

# 缓存配置
BATCH_UPDATE_ENABLED=true

# LinuxDo 相关配置
LINUX_DO_TOKEN_ENDPOINT=https://connect.linux.do/oauth2/token
LINUX_DO_USER_ENDPOINT=https://connect.linux.do/api/user

# SQL 连接池配置
SQL_MAX_IDLE_CONNS=100
SQL_MAX_OPEN_CONNS=1000
SQL_MAX_LIFETIME=60
