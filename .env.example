# Railway 会自动注入以下变量，无需手动配置
# PostgreSQL: PGHOST, PGPORT, PGUSER, PGPASSWORD, PGDATABASE
# Redis: REDISHOST, REDISPORT, REDISUSER, REDIS_PASSWORD

# 数据库连接
ERROR_LOG_ENABLED=true
SQL_DSN=postgresql://${PGUSER}:${PGPASSWORD}@${PGHOST}:${PGPORT}/${PGDATABASE}
SQL_MAX_IDLE_CONNS=100
SQL_MAX_OPEN_CONNS=1000
SQL_MAX_LIFETIME=60

# Redis 连接
REDIS_CONN_STRING=redis://${REDISUSER}:${REDIS_PASSWORD}@${REDISHOST}:${REDISPORT}/0
BATCH_UPDATE_ENABLED=true

# LinuxDo OAuth
LINUX_DO_TOKEN_ENDPOINT=https://connect.linux.do/oauth2/token
LINUX_DO_USER_ENDPOINT=https://connect.linux.do/api/user
